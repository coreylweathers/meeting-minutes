@page "/settings"
@rendermode InteractiveServer
@using MeetingMinutes.Web.Services
@using MeetingMinutes.Shared.Enums
@inject ITranscriptionSettingsService TranscriptionSettings
@inject ILogger<Settings> Logger

<PageTitle>Settings | The Executive Transcript</PageTitle>

<div class="p-6 md:p-10 lg:p-14 bg-surface min-h-[calc(100vh-4rem)]">
    <!-- Hero Header Section -->
    <section class="mb-14 max-w-2xl mx-auto">
        <h1 class="font-headline text-5xl md:text-6xl font-extrabold tracking-tight text-on-surface mb-2">Settings</h1>
        <p class="font-body text-on-surface-variant">Configure your transcription preferences.</p>
    </section>

    @if (isLoading)
    {
        <div class="text-center py-20">
            <span class="material-symbols-outlined text-6xl text-primary animate-spin inline-block">progress_activity</span>
            <p class="mt-6 text-on-surface-variant font-label">Loading settings...</p>
        </div>
    }
    else
    {
        <!-- Transcription Provider Card -->
        <div class="bg-surface-container-low p-8 rounded-xl max-w-2xl mx-auto mb-8">
            <h2 class="font-headline text-xl font-bold text-on-surface mb-2">Transcription Provider</h2>
            <p class="font-body text-on-surface-variant text-sm mb-6">Choose the AI engine used to transcribe your meeting audio.</p>

            <!-- Segmented Control -->
            <div class="flex rounded-lg overflow-hidden border border-outline-variant w-fit mb-4">
                <button
                    class="flex items-center gap-2 px-5 py-2 font-label text-sm transition-all @(currentProvider == SpeechProvider.AzureSpeech ? "bg-primary text-on-primary" : "bg-surface-container text-on-surface-variant hover:bg-surface-container-high")"
                    disabled="@isSaving"
                    @onclick="async () => await SetProvider(SpeechProvider.AzureSpeech)">
                    <span class="material-symbols-outlined text-base">cloud</span>
                    Azure Speech
                </button>
                <button
                    class="flex items-center gap-2 px-5 py-2 font-label text-sm transition-all @(currentProvider == SpeechProvider.Deepgram ? "bg-primary text-on-primary" : "bg-surface-container text-on-surface-variant hover:bg-surface-container-high")"
                    disabled="@isSaving"
                    @onclick="async () => await SetProvider(SpeechProvider.Deepgram)">
                    <span class="material-symbols-outlined text-base">graphic_eq</span>
                    Deepgram
                </button>
            </div>

            @if (showSaved)
            {
                <div class="flex items-center gap-2 text-sm text-primary font-label mt-2 animate-pulse">
                    <span class="material-symbols-outlined text-base">check_circle</span>
                    Saved
                </div>
            }

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="mt-4 flex items-start gap-3 bg-error-container p-4 rounded-lg">
                    <span class="material-symbols-outlined text-error">error</span>
                    <p class="text-sm text-on-error-container">@errorMessage</p>
                </div>
            }
        </div>

        <!-- About Deepgram Card -->
        <div class="bg-surface-container-low p-8 rounded-xl max-w-2xl mx-auto mb-8">
            <h2 class="font-headline text-xl font-bold text-on-surface mb-2">About Deepgram</h2>
            <p class="font-body text-on-surface-variant text-sm">Deepgram Nova-3 provides speaker diarization — transcripts identify individual speakers, giving your summaries richer context.</p>
        </div>
    }
</div>

@code {
    private SpeechProvider currentProvider;
    private bool isLoading = true;
    private bool isSaving;
    private bool showSaved;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            currentProvider = await TranscriptionSettings.GetProviderAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load transcription provider setting");
            errorMessage = $"Failed to load settings: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SetProvider(SpeechProvider provider)
    {
        if (isSaving || provider == currentProvider) return;

        isSaving = true;
        errorMessage = null;

        try
        {
            await TranscriptionSettings.SetProviderAsync(provider);
            currentProvider = provider;
            showSaved = true;
            StateHasChanged();
            await Task.Delay(2000);
            showSaved = false;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to save transcription provider setting");
            errorMessage = $"Failed to save setting: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }
}
