@page "/jobs"
@using MeetingMinutes.Shared.DTOs
@using MeetingMinutes.Shared.Entities
@using MeetingMinutes.Shared.Enums
@inject IJobMetadataService JobMetadata
@inject ILogger<Jobs> Logger
@inject NavigationManager Navigation
@using MeetingMinutes.Web.Services
@implements IDisposable

<PageTitle>Archive | The Executive Transcript</PageTitle>

<!-- Main Content Canvas -->
<div class="p-6 md:p-10 lg:p-14 bg-surface min-h-[calc(100vh-4rem)]">
    <!-- Hero Header Section -->
    <section class="mb-14 max-w-6xl mx-auto">
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
            <div>
                <h1 class="font-headline text-5xl md:text-6xl font-extrabold tracking-tight text-on-surface mb-2">Archive</h1>
                <p class="font-body text-on-surface-variant max-w-md">Access your editorial vault of synthesized meeting intelligence and automated summaries.</p>
            </div>
            <div class="relative w-full md:w-80 group">
                <input class="w-full bg-transparent border-b border-outline-variant/20 py-3 pl-10 focus:outline-none focus:border-primary transition-colors font-body text-sm" placeholder="Search transcripts..." type="text"/>
                <span class="material-symbols-outlined absolute left-0 top-1/2 -translate-y-1/2 text-outline-variant">search</span>
            </div>
        </div>
    </section>

    @if (isLoading)
    {
        <div class="text-center py-20">
            <span class="material-symbols-outlined text-6xl text-primary animate-spin inline-block">progress_activity</span>
            <p class="mt-6 text-on-surface-variant font-label">Loading your archive...</p>
        </div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="max-w-2xl mx-auto bg-error-container p-8 rounded-xl">
            <div class="flex items-start gap-4">
                <span class="material-symbols-outlined text-error text-3xl">error</span>
                <div>
                    <h3 class="font-headline text-lg font-bold text-on-error-container mb-2">Error Loading Archive</h3>
                    <p class="text-on-error-container text-sm">@errorMessage</p>
                </div>
            </div>
        </div>
    }
    else if (jobs == null || !jobs.Any())
    {
        <div class="max-w-2xl mx-auto text-center py-20">
            <span class="material-symbols-outlined text-9xl text-outline-variant mb-6 inline-block">inventory_2</span>
            <h3 class="font-headline text-3xl font-bold text-on-surface mb-4">No meetings yet</h3>
            <p class="text-on-surface-variant mb-8">Upload a meeting video to get started</p>
            <a href="/upload" class="inline-flex items-center gap-2 bg-primary text-on-primary px-8 py-4 rounded-md font-bold text-sm hover:opacity-90 transition-all">
                <span class="material-symbols-outlined">cloud_upload</span>
                Upload Meeting
            </a>
        </div>
    }
    else
    {
        <!-- Stats/Bento Insights -->
        <section class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-14 max-w-6xl mx-auto">
            <div class="bg-surface-container-low p-6 rounded-xl relative overflow-hidden group">
                <div class="relative z-10">
                    <span class="font-label text-xs uppercase tracking-widest text-on-surface-variant mb-4 block">Total Sessions</span>
                    <div class="flex items-baseline gap-2">
                        <span class="font-headline text-4xl font-bold">@jobs.Count</span>
                        <span class="text-xs text-on-surface-variant">Meetings</span>
                    </div>
                </div>
                <div class="absolute -right-4 -bottom-4 opacity-5 group-hover:opacity-10 transition-opacity">
                    <span class="material-symbols-outlined text-[120px]">folder_open</span>
                </div>
            </div>
            <div class="bg-primary-fixed p-6 rounded-xl">
                <span class="font-label text-xs uppercase tracking-widest text-on-primary-fixed-variant mb-4 block">Completed</span>
                <div class="flex items-baseline gap-2">
                    <span class="font-headline text-4xl font-bold text-on-primary-fixed">@jobs.Count(j => j.Status == JobStatus.Completed)</span>
                    <span class="text-xs text-on-primary-fixed-variant">Ready</span>
                </div>
            </div>
            <div class="bg-secondary-container p-6 rounded-xl">
                <span class="font-label text-xs uppercase tracking-widest text-on-secondary-container mb-4 block">Processing</span>
                <div class="flex items-baseline gap-2">
                    <span class="font-headline text-4xl font-bold text-on-secondary-container">@jobs.Count(j => !IsTerminal(j.Status))</span>
                    <span class="text-xs text-on-secondary-container">In Progress</span>
                </div>
            </div>
        </section>

        <!-- Meeting Grid -->
        <section class="max-w-6xl mx-auto">
            <div class="flex items-center justify-between mb-8">
                <h3 class="font-headline text-xl font-bold">Recent Sessions</h3>
                <div class="flex gap-2">
                    <button class="p-2 hover:bg-surface-container-high rounded transition-colors">
                        <span class="material-symbols-outlined">filter_list</span>
                    </button>
                    <button class="p-2 hover:bg-surface-container-high rounded transition-colors">
                        <span class="material-symbols-outlined text-primary">grid_view</span>
                    </button>
                </div>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                @foreach (var job in jobs.OrderByDescending(j => j.CreatedAt))
                {
                    <div class="bg-surface-container-lowest p-8 rounded-xl hover:bg-surface-container-high transition-all group border-l-0 hover:border-l-4 @GetCardBorderClass(job.Status) shadow-[0px_2px_4px_rgba(0,0,0,0.02)]">
                        <div class="flex justify-between items-start mb-6">
                            @if (job.Status == JobStatus.Completed)
                            {
                                <span class="bg-primary-fixed text-on-primary-fixed-variant px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider">Completed</span>
                            }
                            else if (job.Status == JobStatus.Failed)
                            {
                                <span class="bg-error-container text-on-error-container px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider">Error</span>
                            }
                            else
                            {
                                <div class="flex items-center gap-2 bg-secondary-container text-on-secondary-container px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider animate-pulse">
                                    <span>Processing</span>
                                </div>
                            }
                            @if (job.Status == JobStatus.Completed)
                            {
                                <span class="material-symbols-outlined text-outline-variant group-hover:text-primary transition-colors cursor-pointer">more_vert</span>
                            }
                            else if (job.Status == JobStatus.Failed)
                            {
                                <span class="material-symbols-outlined text-error">warning</span>
                            }
                            else
                            {
                                <span class="material-symbols-outlined text-outline-variant">hourglass_empty</span>
                            }
                        </div>
                        <h4 class="font-headline text-xl font-bold mb-2 leading-tight">@job.FileName</h4>
                        <p class="text-xs text-on-surface-variant font-medium mb-6">@FormatDate(job.CreatedAt)</p>
                        
                        @if (!string.IsNullOrEmpty(job.ErrorMessage))
                        {
                            <p class="text-[11px] text-error mb-8 leading-relaxed">@job.ErrorMessage</p>
                        }
                        else if (!IsTerminal(job.Status))
                        {
                            <div class="h-1 w-full bg-surface-container-high rounded-full overflow-hidden mb-8">
                                <div class="h-full bg-primary w-2/3"></div>
                            </div>
                        }
                        else
                        {
                            <div class="mb-8"></div>
                        }
                        
                        @if (job.Status == JobStatus.Completed)
                        {
                            <a href="/jobs/@job.JobId" class="block w-full py-2 bg-surface-container-low text-on-surface text-xs font-bold rounded hover:bg-primary hover:text-on-primary transition-all text-center">View Insights</a>
                        }
                        else if (job.Status == JobStatus.Failed)
                        {
                            <button class="w-full py-2 border border-error/20 text-error text-xs font-bold rounded hover:bg-error hover:text-white transition-all">Retry Upload</button>
                        }
                        else
                        {
                            <button class="w-full py-2 bg-surface-container-low text-on-surface-variant text-xs font-bold rounded opacity-50 cursor-not-allowed" disabled>Generating Summary...</button>
                        }
                    </div>
                }
            </div>
        </section>
        
        <!-- Bottom Spacing -->
        <div class="h-20"></div>
    }
</div>

@code {
    private List<JobDto>? jobs;
    private bool isLoading = true;
    private string? errorMessage;
    private System.Threading.Timer? _refreshTimer;

    protected override async Task OnInitializedAsync()
    {
        await LoadJobsAsync();
        StartPollingIfNeeded();
    }

    private async Task LoadJobsAsync()
    {
        try
        {
            isLoading = jobs == null;
            errorMessage = null;
            var result = await JobMetadata.ListJobsAsync();
            jobs = result.Select(j => MapToJobDto(j)).ToList();
            StartPollingIfNeeded();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load jobs");
            errorMessage = $"Failed to load jobs: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void StartPollingIfNeeded()
    {
        _refreshTimer?.Dispose();
        _refreshTimer = null;

        if (jobs?.Any(j => !IsTerminal(j.Status)) == true)
        {
            _refreshTimer = new System.Threading.Timer(async _ =>
            {
                await LoadJobsAsync();
                await InvokeAsync(StateHasChanged);
            }, null, 5000, 5000);
        }
    }

    private bool IsTerminal(JobStatus status)
    {
        return status == JobStatus.Completed || status == JobStatus.Failed;
    }

    private string GetCardBorderClass(JobStatus status)
    {
        return status switch
        {
            JobStatus.Completed => "border-primary",
            JobStatus.Failed => "border-error",
            _ => "border-primary"
        };
    }

    private string FormatDate(DateTimeOffset date)
    {
        var timeSpan = DateTimeOffset.UtcNow - date;

        if (timeSpan.TotalMinutes < 1)
            return "Just now";
        if (timeSpan.TotalMinutes < 60)
            return $"{(int)timeSpan.TotalMinutes} minute{((int)timeSpan.TotalMinutes == 1 ? "" : "s")} ago";
        if (timeSpan.TotalHours < 24)
            return $"{(int)timeSpan.TotalHours} hour{((int)timeSpan.TotalHours == 1 ? "" : "s")} ago";
        if (timeSpan.TotalDays < 7)
            return $"{(int)timeSpan.TotalDays} day{((int)timeSpan.TotalDays == 1 ? "" : "s")} ago";

        return date.LocalDateTime.ToString("MMM dd, yyyy 'at' h:mm tt");
    }

    public void Dispose()
    {
        _refreshTimer?.Dispose();
    }

    private static JobDto MapToJobDto(ProcessingJob job) => new(
        job.JobId, job.FileName, Enum.Parse<JobStatus>(job.Status),
        job.BlobUri, job.TranscriptBlobUri, job.SummaryBlobUri,
        job.ErrorMessage, job.CreatedAt, job.UpdatedAt
    );
}
