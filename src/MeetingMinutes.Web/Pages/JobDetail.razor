@page "/jobs/{Id}"
@inject IJobMetadataService JobMetadata
@inject IBlobStorageService BlobStorage
@inject ISummarizationService Summarizer
@inject ILogger<JobDetail> Logger
@inject IJSRuntime JS
@using MeetingMinutes.Shared.DTOs
@using MeetingMinutes.Shared.Entities
@using MeetingMinutes.Shared.Enums
@using MeetingMinutes.Web.Services
@using System.Timers
@implements IDisposable

<PageTitle>@(job?.FileName ?? "Job Detail") | The Executive Transcript</PageTitle>

<div class="bg-surface min-h-screen">
    @if (isLoading)
    {
        <div class="flex items-center justify-center py-32">
            <div class="text-center">
                <span class="material-symbols-outlined text-6xl text-primary animate-spin inline-block">progress_activity</span>
                <p class="mt-6 text-on-surface-variant font-label">Loading job details...</p>
            </div>
        </div>
    }
    else if (job == null)
    {
        <div class="max-w-2xl mx-auto py-20 px-8">
            <div class="bg-error-container p-8 rounded-xl text-center">
                <span class="material-symbols-outlined text-6xl text-error mb-4 inline-block">error</span>
                <h3 class="font-headline text-2xl font-bold text-on-error-container mb-2">Job Not Found</h3>
                <p class="text-on-error-container mb-6">The requested job could not be found.</p>
                <a href="/jobs" class="inline-flex items-center gap-2 bg-error text-on-error px-6 py-3 rounded-md font-bold text-sm hover:opacity-90 transition-all">
                    <span class="material-symbols-outlined">arrow_back</span>
                    Back to Archive
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="px-8 py-10 max-w-7xl mx-auto">
            <!-- Navigation -->
            <div class="mb-6">
                <a href="/jobs" class="inline-flex items-center gap-2 text-on-surface-variant hover:text-primary transition-colors font-label">
                    <span class="material-symbols-outlined">arrow_back</span>
                    Back to Archive
                </a>
            </div>

            <!-- Metadata Row -->
            <div class="mb-12 flex flex-col md:flex-row md:items-end justify-between gap-6">
                <div>
                    <div class="flex items-center gap-3 mb-2">
                        @if (job.Status == JobStatus.Completed)
                        {
                            <span class="bg-primary-fixed text-on-primary-fixed-variant px-3 py-1 text-xs font-bold rounded-full uppercase tracking-widest">Completed</span>
                        }
                        else if (job.Status == JobStatus.Failed)
                        {
                            <span class="bg-error-container text-on-error-container px-3 py-1 text-xs font-bold rounded-full uppercase tracking-widest">Error</span>
                        }
                        else if (job.Status == JobStatus.Transcribed)
                        {
                            <span class="bg-tertiary-container text-on-tertiary-container px-3 py-1 text-xs font-bold rounded-full uppercase tracking-widest">Ready to Review</span>
                        }
                        else
                        {
                            <span class="bg-secondary-container text-on-secondary-container px-3 py-1 text-xs font-bold rounded-full uppercase tracking-widest animate-pulse">Processing</span>
                        }
                        <span class="text-on-surface-variant text-sm font-medium">@job.CreatedAt.ToString("MMMM dd, yyyy")</span>
                    </div>
                    <h2 class="text-5xl font-extrabold tracking-tight text-primary font-headline">@job.FileName</h2>
                    @if (!string.IsNullOrEmpty(job.ErrorMessage))
                    {
                        <div class="mt-4 bg-error-container p-4 rounded-lg border-l-4 border-error">
                            <p class="text-on-error-container text-sm"><strong>Error:</strong> @job.ErrorMessage</p>
                        </div>
                    }
                </div>
            </div>

            @if (IsProcessing())
            {
                <div class="mb-12 bg-secondary-container p-8 rounded-xl">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-full border-4 border-on-secondary-container border-t-transparent animate-spin"></div>
                        <div>
                            <h3 class="font-headline text-xl font-bold text-on-secondary-container mb-1">Processing in Progress</h3>
                            <p class="text-on-secondary-container/80 text-sm">Your meeting is being transcribed and analyzed...</p>
                        </div>
                    </div>
                </div>
            }

            @if (job.Status == JobStatus.Completed || job.Status == JobStatus.Transcribed)
            {
                @if (job.Status == JobStatus.Transcribed)
                {
                    <div class="mb-10 bg-tertiary-container p-8 rounded-xl">
                        <div class="flex items-start gap-4 mb-6">
                            <span class="material-symbols-outlined text-3xl text-on-tertiary-container mt-1">task_alt</span>
                            <div>
                                <h3 class="font-headline text-xl font-bold text-on-tertiary-container mb-1">Transcription Complete</h3>
                                <p class="text-on-tertiary-container/80 text-sm">Your meeting has been transcribed. Choose how to proceed:</p>
                            </div>
                        </div>
                        <div class="flex flex-wrap gap-3">
                            <button class="flex items-center gap-2 bg-primary text-on-primary px-6 py-3 rounded-md font-bold hover:opacity-90 transition-all disabled:opacity-60"
                                    @onclick="SummarizeJob" disabled="@isActioning">
                                @if (isActioning && actioningMode == "summarize")
                                {
                                    <div class="w-4 h-4 rounded-full border-2 border-on-primary border-t-transparent animate-spin"></div>
                                }
                                else
                                {
                                    <span class="material-symbols-outlined text-sm">auto_awesome</span>
                                }
                                Summarize with AI
                            </button>
                            <button class="flex items-center gap-2 bg-surface-container text-on-surface px-6 py-3 rounded-md font-bold hover:bg-surface-dim transition-all disabled:opacity-60"
                                    @onclick="DownloadTranscript" disabled="@isActioning">
                                <span class="material-symbols-outlined text-sm">download</span>
                                Download Transcript
                            </button>
                            <button class="flex items-center gap-2 bg-surface-container-low text-on-surface-variant px-6 py-3 rounded-md font-bold hover:bg-surface-dim transition-all disabled:opacity-60"
                                    @onclick="CompleteJob" disabled="@isActioning">
                                @if (isActioning && actioningMode == "complete")
                                {
                                    <div class="w-4 h-4 rounded-full border-2 border-on-surface border-t-transparent animate-spin"></div>
                                }
                                else
                                {
                                    <span class="material-symbols-outlined text-sm">check_circle</span>
                                }
                                Complete Job
                            </button>
                        </div>
                        @if (!string.IsNullOrEmpty(actionError))
                        {
                            <p class="mt-4 text-sm text-error">@actionError</p>
                        }
                    </div>
                }

                <!-- Bento Layout Content -->
                <div class="grid grid-cols-12 gap-10">
                    <!-- AI Summary Column -->
                    <div class="col-span-12 lg:col-span-5 space-y-10">
                        @if (summaryLoading)
                        {
                            <div class="bg-surface-container-low rounded-xl p-8">
                                <span class="material-symbols-outlined text-primary text-4xl animate-spin inline-block">progress_activity</span>
                                <p class="mt-4 text-on-surface-variant">Loading summary...</p>
                            </div>
                        }
                        else if (summary != null)
                        {
                            <section class="bg-surface-container-low rounded-xl p-8 relative overflow-hidden border-l-4 border-on-tertiary-container">
                                <div class="absolute top-0 right-0 p-4 opacity-10">
                                    <span class="material-symbols-outlined text-6xl" style="font-variation-settings: 'FILL' 1;">auto_awesome</span>
                                </div>
                                <div class="flex items-center justify-between mb-6">
                                    <h3 class="text-on-tertiary-container font-headline font-bold text-xl flex items-center gap-2">
                                        <span class="material-symbols-outlined text-on-tertiary-container">auto_awesome</span>
                                        Executive Intelligence
                                    </h3>
                                    @if (!isEditMode)
                                    {
                                        <button class="text-primary hover:text-on-tertiary-container transition-colors" @onclick="ToggleEditMode">
                                            <span class="material-symbols-outlined">edit</span>
                                        </button>
                                    }
                                </div>

                                @if (isEditMode)
                                {
                                    <!-- Edit Mode -->
                                    <div class="space-y-4">
                                        <div>
                                            <label class="text-xs uppercase tracking-widest font-bold text-on-surface-variant mb-2 block">Title</label>
                                            <input type="text" class="w-full bg-surface-container-lowest border border-outline-variant rounded-md px-4 py-2 text-sm focus:ring-2 focus:ring-primary outline-none" @bind="editTitle" />
                                        </div>
                                        <div>
                                            <label class="text-xs uppercase tracking-widest font-bold text-on-surface-variant mb-2 block">Duration (minutes)</label>
                                            <input type="number" class="w-full bg-surface-container-lowest border border-outline-variant rounded-md px-4 py-2 text-sm focus:ring-2 focus:ring-primary outline-none" @bind="editDurationMinutes" />
                                        </div>
                                        <div>
                                            <label class="text-xs uppercase tracking-widest font-bold text-on-surface-variant mb-2 block">Attendees (comma-separated)</label>
                                            <textarea class="w-full bg-surface-container-lowest border border-outline-variant rounded-md px-4 py-2 text-sm focus:ring-2 focus:ring-primary outline-none" rows="3" @bind="editAttendees"></textarea>
                                        </div>
                                        <div>
                                            <label class="text-xs uppercase tracking-widest font-bold text-on-surface-variant mb-2 block">Key Points (one per line)</label>
                                            <textarea class="w-full bg-surface-container-lowest border border-outline-variant rounded-md px-4 py-2 text-sm focus:ring-2 focus:ring-primary outline-none" rows="5" @bind="editKeyPoints"></textarea>
                                        </div>
                                        <div>
                                            <label class="text-xs uppercase tracking-widest font-bold text-on-surface-variant mb-2 block">Action Items (one per line)</label>
                                            <textarea class="w-full bg-surface-container-lowest border border-outline-variant rounded-md px-4 py-2 text-sm focus:ring-2 focus:ring-primary outline-none" rows="5" @bind="editActionItems"></textarea>
                                        </div>
                                        <div>
                                            <label class="text-xs uppercase tracking-widest font-bold text-on-surface-variant mb-2 block">Decisions (one per line)</label>
                                            <textarea class="w-full bg-surface-container-lowest border border-outline-variant rounded-md px-4 py-2 text-sm focus:ring-2 focus:ring-primary outline-none" rows="5" @bind="editDecisions"></textarea>
                                        </div>
                                        <div class="flex gap-3 pt-4">
                                            <button class="flex-1 bg-primary text-on-primary py-3 rounded-md font-bold hover:opacity-90 transition-all" @onclick="SaveSummary" disabled="@isSaving">
                                                @if (isSaving)
                                                {
                                                    <div class="w-5 h-5 rounded-full border-2 border-on-primary border-t-transparent animate-spin inline-block mr-2"></div>
                                                }
                                                Save
                                            </button>
                                            <button class="px-6 bg-surface-container text-on-surface py-3 rounded-md font-bold hover:bg-surface-dim transition-all" @onclick="CancelEdit" disabled="@isSaving">Cancel</button>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <!-- Display Mode -->
                                    <div class="space-y-8">
                                        <div>
                                            <h4 class="text-xs uppercase tracking-widest font-bold text-on-surface-variant mb-3">Meeting Title</h4>
                                            <p class="text-lg text-on-surface leading-relaxed font-body">@summary.Title</p>
                                        </div>
                                        @if (summary.KeyPoints?.Any() == true)
                                        {
                                            <div>
                                                <h4 class="text-xs uppercase tracking-widest font-bold text-on-surface-variant mb-3">Core Objectives</h4>
                                                <ul class="space-y-3">
                                                    @foreach (var point in summary.KeyPoints)
                                                    {
                                                        <li class="flex gap-3">
                                                            <span class="material-symbols-outlined text-on-tertiary-container mt-1">check_circle</span>
                                                            <p class="text-on-surface">@point</p>
                                                        </li>
                                                    }
                                                </ul>
                                            </div>
                                        }
                                        @if (summary.Decisions?.Any() == true)
                                        {
                                            <div>
                                                <h4 class="text-xs uppercase tracking-widest font-bold text-on-surface-variant mb-3">Key Decisions</h4>
                                                <ul class="space-y-3">
                                                    @foreach (var decision in summary.Decisions)
                                                    {
                                                        <li class="flex gap-3">
                                                            <span class="material-symbols-outlined text-on-tertiary-container mt-1">check_circle</span>
                                                            <p class="text-on-surface">@decision</p>
                                                        </li>
                                                    }
                                                </ul>
                                            </div>
                                        }
                                        @if (summary.ActionItems?.Any() == true)
                                        {
                                            <div class="bg-surface-container-lowest p-6 rounded-lg shadow-sm">
                                                <h4 class="text-xs uppercase tracking-widest font-bold text-on-tertiary-container mb-4">Critical Action Items</h4>
                                                <div class="space-y-3">
                                                    @foreach (var item in summary.ActionItems)
                                                    {
                                                        <div class="flex items-center gap-3">
                                                            <div class="w-2 h-2 rounded-full bg-on-tertiary-container"></div>
                                                            <span class="text-on-surface font-medium">@item</span>
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                            </section>

                            <!-- Participant Sidebar Block -->
                            @if (summary.Attendees?.Any() == true)
                            {
                                <div class="bg-surface-container-low rounded-xl p-8">
                                    <h4 class="text-xs uppercase tracking-widest font-bold text-on-surface-variant mb-6">Participants (@summary.Attendees.Length)</h4>
                                    <div class="grid grid-cols-2 gap-4">
                                        @foreach (var attendee in summary.Attendees)
                                        {
                                            <div class="flex items-center gap-3">
                                                <div class="w-10 h-10 rounded-full bg-primary-fixed flex items-center justify-center text-xs font-bold text-on-primary-fixed">
                                                    @GetInitials(attendee)
                                                </div>
                                                <div>
                                                    <p class="text-sm font-bold text-on-surface">@attendee</p>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="bg-surface-container-low rounded-xl p-8">
                                <p class="text-on-surface-variant">No summary available.</p>
                            </div>
                        }
                    </div>

                    <!-- Transcript Column -->
                    <div class="col-span-12 lg:col-span-7">
                        <div class="bg-surface-container-lowest rounded-xl p-8 shadow-sm">
                            <div class="flex items-center justify-between mb-8">
                                <h3 class="font-headline font-bold text-xl text-primary">Full Transcript</h3>
                                <div class="flex gap-3">
                                    <div class="relative w-48">
                                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline text-sm">search</span>
                                        <input class="w-full pl-9 pr-4 py-2 text-sm bg-transparent border-b border-outline-variant/20 focus:border-primary focus:ring-0 outline-none transition-all" placeholder="Search..." type="text"/>
                                    </div>
                                    <button class="flex items-center gap-2 px-4 py-2 bg-surface-container hover:bg-surface-dim rounded-md transition-colors" @onclick="CopyTranscript">
                                        <span class="material-symbols-outlined text-sm">content_copy</span>
                                        <span class="text-sm font-medium">Copy</span>
                                    </button>
                                </div>
                            </div>
                            @if (transcriptLoading)
                            {
                                <div class="py-12 text-center">
                                    <span class="material-symbols-outlined text-4xl text-primary animate-spin inline-block">progress_activity</span>
                                    <p class="mt-4 text-on-surface-variant">Loading transcript...</p>
                                </div>
                            }
                            else if (!string.IsNullOrEmpty(transcript))
                            {
                                <div class="prose prose-sm max-w-none overflow-y-auto max-h-[600px] pr-2">
                                    <pre class="text-on-surface-variant leading-relaxed text-[15px] font-body whitespace-pre-wrap">@transcript</pre>
                                </div>
                            }
                            else
                            {
                                <p class="text-on-surface-variant py-8">No transcript available.</p>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter]
    public string Id { get; set; } = string.Empty;

    private JobDto? job;
    private string? transcript;
    private SummaryDto? summary;
    private bool isLoading = true;
    private bool transcriptLoading = false;
    private bool summaryLoading = false;
    private bool isEditMode = false;
    private bool isSaving = false;
    private bool isActioning = false;
    private string actioningMode = string.Empty;
    private string? actionError;
    private Timer? pollTimer;

    // Edit mode fields
    private string editTitle = string.Empty;
    private int editDurationMinutes;
    private string editAttendees = string.Empty;
    private string editKeyPoints = string.Empty;
    private string editActionItems = string.Empty;
    private string editDecisions = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadJob();
    }

    private async Task LoadJob()
    {
        try
        {
            isLoading = true;
            var entity = await JobMetadata.GetJobAsync(Id);
            job = entity is null ? null : MapToJobDto(entity);
            if (job?.Status == JobStatus.Transcribed)
            {
                StopPolling();
                await LoadTranscript();
            }
            else if (job?.Status == JobStatus.Completed)
            {
                StopPolling();
                await LoadTranscript();
                await LoadSummary();
            }
            else if (IsProcessing()) StartPolling();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading job {JobId}", Id);
        }
        finally { isLoading = false; }
    }

    private async Task LoadTranscript()
    {
        try
        {
            transcriptLoading = true;
            var entity = await JobMetadata.GetJobAsync(Id);
            if (entity?.TranscriptBlobUri is not null)
                transcript = await BlobStorage.DownloadTextAsync(entity.TranscriptBlobUri);
        }
        catch (Exception ex) { Logger.LogError(ex, "Error loading transcript for job {JobId}", Id); }
        finally { transcriptLoading = false; }
    }

    private async Task LoadSummary()
    {
        try
        {
            summaryLoading = true;
            var entity = await JobMetadata.GetJobAsync(Id);
            if (entity?.SummaryBlobUri is not null)
            {
                var json = await BlobStorage.DownloadTextAsync(entity.SummaryBlobUri);
                if (json is not null)
                    summary = System.Text.Json.JsonSerializer.Deserialize<SummaryDto>(json,
                        new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
            }
        }
        catch (Exception ex) { Logger.LogError(ex, "Error loading summary for job {JobId}", Id); }
        finally { summaryLoading = false; }
    }

    private void StartPolling()
    {
        StopPolling();
        pollTimer = new Timer(5000);
        pollTimer.Elapsed += async (sender, e) => await OnPollTick();
        pollTimer.Start();
    }

    private void StopPolling()
    {
        if (pollTimer != null)
        {
            pollTimer.Stop();
            pollTimer.Dispose();
            pollTimer = null;
        }
    }

    private async Task OnPollTick()
    {
        try
        {
            var entity = await JobMetadata.GetJobAsync(Id);
            if (entity != null)
            {
                job = MapToJobDto(entity);

                if (job.Status == JobStatus.Transcribed)
                {
                    StopPolling();
                    await LoadTranscript();
                }
                else if (job.Status == JobStatus.Completed || job.Status == JobStatus.Failed)
                {
                    StopPolling();

                    if (job.Status == JobStatus.Completed)
                    {
                        await LoadTranscript();
                        await LoadSummary();
                    }
                }

                await InvokeAsync(StateHasChanged);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error polling job {JobId}", Id);
        }
    }

    private bool IsProcessing()
    {
        return job?.Status == JobStatus.Pending ||
               job?.Status == JobStatus.ExtractingAudio ||
               job?.Status == JobStatus.Transcribing ||
               job?.Status == JobStatus.Summarizing;
    }

    private string GetStatusBadgeClass()
    {
        return job?.Status switch
        {
            JobStatus.Completed => "bg-success",
            JobStatus.Failed => "bg-danger",
            _ => "bg-warning"
        };
    }

    private string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "??";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 0) return "??";
        if (parts.Length == 1) return parts[0].Substring(0, Math.Min(2, parts[0].Length)).ToUpper();
        return (parts[0][0].ToString() + parts[^1][0].ToString()).ToUpper();
    }

    private async Task CopyTranscript()
    {
        if (!string.IsNullOrEmpty(transcript))
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", transcript);
        }
    }

    private async Task SummarizeJob()
    {
        isActioning = true;
        actioningMode = "summarize";
        actionError = null;
        StateHasChanged();
        try
        {
            var entity = await JobMetadata.GetJobAsync(Id);
            if (entity == null || entity.Status != JobStatus.Transcribed.ToString())
            {
                actionError = "Job not in Transcribed state";
                return;
            }
            if (string.IsNullOrEmpty(entity.TranscriptBlobUri))
            {
                actionError = "No transcript available";
                return;
            }

            await JobMetadata.UpdateStatusAsync(Id, JobStatus.Summarizing);

            var transcriptText = await BlobStorage.DownloadTextAsync(entity.TranscriptBlobUri);
            if (string.IsNullOrEmpty(transcriptText))
            {
                actionError = "Could not read transcript";
                await JobMetadata.UpdateStatusAsync(Id, JobStatus.Failed, "Could not read transcript");
                return;
            }

            var summaryDto = await Summarizer.SummarizeAsync(transcriptText);
            var summaryJson = System.Text.Json.JsonSerializer.Serialize(summaryDto, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
            var summaryBlobUri = await BlobStorage.UploadSummaryAsync(summaryJson, $"{Id}.json");

            entity = await JobMetadata.GetJobAsync(Id);
            if (entity is not null)
            {
                entity.SummaryBlobUri = summaryBlobUri;
                await JobMetadata.UpdateJobAsync(entity);
            }

            await JobMetadata.UpdateStatusAsync(Id, JobStatus.Completed);
            await LoadJob();
        }
        catch (Exception ex)
        {
            actionError = $"Error: {ex.Message}";
            Logger.LogError(ex, "Error summarizing job {JobId}", Id);
            try { await JobMetadata.UpdateStatusAsync(Id, JobStatus.Failed, ex.Message); } catch { /* best effort */ }
        }
        finally
        {
            isActioning = false;
            StateHasChanged();
        }
    }

    private async Task CompleteJob()
    {
        isActioning = true;
        actioningMode = "complete";
        actionError = null;
        StateHasChanged();
        try
        {
            await JobMetadata.UpdateStatusAsync(Id, JobStatus.Completed);
            await LoadJob();
        }
        catch (Exception ex)
        {
            actionError = $"Error: {ex.Message}";
            Logger.LogError(ex, "Error completing job {JobId}", Id);
        }
        finally
        {
            isActioning = false;
            StateHasChanged();
        }
    }

    private async Task DownloadTranscript()
    {
        if (!string.IsNullOrEmpty(transcript))
        {
            var fileName = $"{job?.FileName ?? Id}_transcript.txt";
            await JS.InvokeVoidAsync("downloadTextAsFile", fileName, transcript);
        }
    }

    private void ToggleEditMode()
    {
        isEditMode = true;
        InitializeEditFields();
    }

    private void InitializeEditFields()
    {
        if (summary != null)
        {
            editTitle = summary.Title;
            editDurationMinutes = summary.DurationMinutes;
            editAttendees = string.Join(", ", summary.Attendees);
            editKeyPoints = string.Join("\n", summary.KeyPoints);
            editActionItems = string.Join("\n", summary.ActionItems);
            editDecisions = string.Join("\n", summary.Decisions);
        }
    }

    private void CancelEdit()
    {
        isEditMode = false;
    }

    private async Task SaveSummary()
    {
        try
        {
            isSaving = true;
            var entity = await JobMetadata.GetJobAsync(Id);
            if (entity is null) return;

            var updated = new SummaryDto(
                editTitle,
                editAttendees.Split(',').Select(a => a.Trim()).Where(a => !string.IsNullOrWhiteSpace(a)).ToArray(),
                editKeyPoints.Split('\n').Select(k => k.Trim()).Where(k => !string.IsNullOrWhiteSpace(k)).ToArray(),
                editActionItems.Split('\n').Select(a => a.Trim()).Where(a => !string.IsNullOrWhiteSpace(a)).ToArray(),
                editDecisions.Split('\n').Select(d => d.Trim()).Where(d => !string.IsNullOrWhiteSpace(d)).ToArray(),
                editDurationMinutes
            );

            var json = System.Text.Json.JsonSerializer.Serialize(updated);

            if (entity.SummaryBlobUri is not null)
                await BlobStorage.UploadTextAsync(json, $"{Id}.json");

            await LoadSummary();
            isEditMode = false;
            Logger.LogInformation("Summary updated for job {JobId}", Id);
        }
        catch (Exception ex) { Logger.LogError(ex, "Error saving summary for job {JobId}", Id); }
        finally { isSaving = false; }
    }

    private static JobDto MapToJobDto(ProcessingJob job) => new(
        job.JobId, job.FileName, Enum.Parse<JobStatus>(job.Status),
        job.BlobUri, job.TranscriptBlobUri, job.SummaryBlobUri,
        job.ErrorMessage, job.CreatedAt, job.UpdatedAt
    );

    public void Dispose()
    {
        StopPolling();
    }
}
