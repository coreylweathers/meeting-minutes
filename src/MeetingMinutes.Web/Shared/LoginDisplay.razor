<AuthorizeView>
    <Authorized>
        <span class="text-light me-3">Hello, @context.User.Identity?.Name!</span>
        <a href="/auth/logout" class="btn btn-sm btn-outline-light">Log out</a>
    </Authorized>
    <NotAuthorized>
        <a href="/auth/login/microsoft" class="btn btn-sm btn-primary me-2">Sign in with Microsoft</a>
        <a href="/auth/login/google" class="btn btn-sm btn-outline-light">Sign in with Google</a>
    </NotAuthorized>
</AuthorizeView>
