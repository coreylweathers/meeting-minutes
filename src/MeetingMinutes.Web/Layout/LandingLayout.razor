@inherits LayoutComponentBase

<!-- Landing Page Layout (no sidebar) -->
<div class="min-h-screen flex flex-col">
    <!-- Top Navigation -->
    <header class="fixed top-0 z-50 w-full bg-slate-50 dark:bg-slate-950 flex justify-between items-center px-8 h-16">
        <div class="flex items-center gap-8">
            <a href="/" class="font-headline text-xl font-black text-slate-900 dark:text-slate-50">The Executive Transcript</a>
            <nav class="hidden md:flex gap-6 items-center">
                <a class="font-headline font-extrabold tracking-tight uppercase text-sm text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-50 transition-colors" href="/jobs">Dashboard</a>
                <a class="font-headline font-extrabold tracking-tight uppercase text-sm text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-50 transition-colors" href="#">Solutions</a>
                <a class="font-headline font-extrabold tracking-tight uppercase text-sm text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-50 transition-colors" href="#">Pricing</a>
            </nav>
        </div>
        <div class="flex items-center gap-4">
            <div class="hidden sm:block relative">
                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-sm">search</span>
                <input class="bg-surface-container-low border-none rounded-full py-1.5 pl-9 pr-4 text-xs font-medium focus:ring-1 focus:ring-primary outline-none w-48" placeholder="Search insights..." type="text"/>
            </div>
            <span class="material-symbols-outlined text-slate-600 dark:text-slate-400 cursor-pointer">account_circle</span>
        </div>
    </header>

    <!-- Main Content -->
    <main class="pt-16 flex-1">
        @Body
    </main>

    <!-- Footer -->
    <footer class="bg-surface-container-low py-8 mt-auto">
        <div class="container mx-auto px-8 text-center">
            <p class="text-sm text-on-surface-variant">&copy; The Executive Transcript. Digital Curation for Leaders.</p>
        </div>
    </footer>
</div>
